<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".feature.vacancy.ui.VacancyFragment">

    <com.google.android.material.textview.MaterialTextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginVertical="19dp"
        android:layout_marginStart="56dp"
        android:fontFamily="@font/ys_display_medium"
        android:text="@string/vacancy"
        android:textColor="?attr/colorOnBackgroundPrimary"
        android:textSize="22sp" />

    <ImageButton
        android:id="@+id/back"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        style="@style/HeaderImageButtonStyle"
        android:layout_marginStart="@dimen/padding_8"
        android:src="@drawable/ic_back"
        android:contentDescription="@string/search_vacancies"/>

    <ImageButton
        android:id="@+id/add_to_favorites"
        style="@style/HeaderImageButtonStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginEnd="@dimen/padding_12"
        android:src="@drawable/ic_favorites_off"
        android:contentDescription="@string/favorites" />

    <ImageButton
        android:id="@+id/delete_from_favorites"
        style="@style/HeaderImageButtonStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginEnd="@dimen/padding_12"
        android:src="@drawable/ic_favorites_on"
        android:contentDescription="@string/favorites"
        android:visibility="gone"/>

    <ImageButton
        android:id="@+id/share"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        style="@style/HeaderImageButtonStyle"
        android:layout_gravity="end"
        android:layout_marginEnd="64dp"
        android:src="@drawable/ic_sharing"/>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        tools:visibility="visible">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/start_16_line"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_begin="@dimen/padding_16" />

            <androidx.constraintlayout.widget.Guideline
                android:id="@+id/end_16_line"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                app:layout_constraintGuide_end="@dimen/padding_16" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/vacancy_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/VacancyMultiLineTextViewStyle"
                android:fontFamily="@font/ys_display_bold"
                android:paddingTop="@dimen/padding_8"
                android:textSize="@dimen/text_size_32"
                app:layout_constraintEnd_toStartOf="@id/end_16_line"
                app:layout_constraintStart_toEndOf="@id/start_16_line"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="Full Stack Developer в Amazon" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/vacancy_salary"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/VacancyMultiLineTextViewStyle"
                android:fontFamily="@font/ys_display_medium"
                android:paddingBottom="@dimen/padding_8"
                android:textSize="@dimen/text_size_22"
                android:layout_marginTop="4dp"
                app:layout_constraintEnd_toStartOf="@id/end_16_line"
                app:layout_constraintStart_toEndOf="@id/start_16_line"
                app:layout_constraintTop_toBottomOf="@id/vacancy_name"
                tools:text="от 1 200 GBP до 2 200 GBP" />

            <androidx.cardview.widget.CardView
                android:id="@+id/employer_info"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_16"
                app:cardBackgroundColor="@color/light_gray"
                app:cardCornerRadius="12dp"
                app:contentPadding="@dimen/padding_16"
                app:layout_constraintEnd_toStartOf="@id/end_16_line"
                app:layout_constraintStart_toEndOf="@id/start_16_line"
                app:layout_constraintTop_toBottomOf="@id/vacancy_salary"
                app:cardElevation="0dp">

                <com.google.android.material.imageview.ShapeableImageView
                    android:id="@+id/employer_logo"
                    android:layout_width="@dimen/company_logotype_size"
                    android:layout_height="@dimen/company_logotype_size"
                    android:scaleType="centerCrop"
                    android:src="@drawable/ic_placeholder"
                    android:background="@null"
                    app:shapeAppearance="@style/RoundedShapeAppearance" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/employer_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/VacancyEmployerTextViewStyle"
                    android:fontFamily="@font/ys_display_medium"
                    android:textSize="@dimen/text_size_22"
                    tools:text="Amazon" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/region_city"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/VacancyEmployerTextViewStyle"
                    android:layout_gravity="top"
                    android:layout_marginTop="26dp"
                    android:fontFamily="@font/ys_display_regular"
                    android:textSize="@dimen/text_size_16"
                    tools:text="Москва" />
            </androidx.cardview.widget.CardView>

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/required_experience_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/VacancySingleLineTextViewStyle"
                android:fontFamily="@font/ys_display_medium"
                android:textSize="@dimen/text_size_16"
                app:layout_constraintEnd_toStartOf="@id/end_16_line"
                app:layout_constraintHorizontal_bias="0"
                app:layout_constraintStart_toEndOf="@id/start_16_line"
                app:layout_constraintTop_toBottomOf="@id/employer_info"
                android:layout_marginTop="24dp"
                android:text="@string/required_experience" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/required_experience"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/VacancyDetailsSingleTextViewStyle"
                app:layout_constraintEnd_toStartOf="@id/end_16_line"
                app:layout_constraintHorizontal_bias="0"
                app:layout_constraintStart_toEndOf="@id/start_16_line"
                app:layout_constraintTop_toBottomOf="@id/required_experience_label"
                android:layout_marginTop="4dp"
                tools:text="Нет опыта" />

            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/employment_schedule"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/VacancyDetailsTextViewStyle"
                android:layout_marginTop="@dimen/padding_8"
                app:layout_constraintEnd_toStartOf="@id/end_16_line"
                app:layout_constraintStart_toEndOf="@id/start_16_line"
                app:layout_constraintTop_toBottomOf="@id/required_experience"
                tools:text="Полная занятость, полный день" />
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/vacancy_description_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/VacancyDetailsHeaderTextViewStyle"
                android:layout_marginTop="32dp"
                app:layout_constraintEnd_toStartOf="@id/end_16_line"
                app:layout_constraintStart_toEndOf="@id/start_16_line"
                app:layout_constraintTop_toBottomOf="@id/employment_schedule"
                android:text="@string/vacancy_description" />
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/vacancy_description"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/VacancyDetailsTextViewStyle"
                android:layout_marginTop="@dimen/padding_16"
                app:layout_constraintEnd_toStartOf="@id/end_16_line"
                app:layout_constraintStart_toEndOf="@id/start_16_line"
                app:layout_constraintTop_toBottomOf="@id/vacancy_description_label"
                tools:text="Описание вакансии" />
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/vacancy_skills_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/VacancyDetailsHeaderTextViewStyle"
                android:layout_marginTop="24dp"
                app:layout_constraintEnd_toStartOf="@id/end_16_line"
                app:layout_constraintStart_toEndOf="@id/start_16_line"
                app:layout_constraintTop_toBottomOf="@id/vacancy_description"
                android:text="@string/key_skills" />
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/vacancy_skills"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/VacancyDetailsTextViewStyle"
                android:layout_marginTop="@dimen/padding_16"
                app:layout_constraintEnd_toStartOf="@id/end_16_line"
                app:layout_constraintStart_toEndOf="@id/start_16_line"
                app:layout_constraintTop_toBottomOf="@id/vacancy_skills_label"
                tools:text="Ключевые вакансии" />
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/vacancy_contacts_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/VacancyDetailsHeaderTextViewStyle"
                android:layout_marginTop="24dp"
                app:layout_constraintEnd_toStartOf="@id/end_16_line"
                app:layout_constraintStart_toEndOf="@id/start_16_line"
                app:layout_constraintTop_toBottomOf="@id/vacancy_skills"
                android:text="@string/contacts" />
            <com.google.android.material.textview.MaterialTextView
                android:id="@+id/vacancy_contact_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                style="@style/VacancyDetailsSingleTextViewStyle"
                android:layout_marginTop="24dp"
                app:layout_constraintEnd_toStartOf="@id/end_16_line"
                app:layout_constraintStart_toEndOf="@id/start_16_line"
                app:layout_constraintTop_toBottomOf="@id/vacancy_contacts_label"
                tools:text="Попов Андрей Сергеевич" />
            <com.google.android.material.button.MaterialButton
                android:id="@+id/vacancy_contact_email"
                style="@style/EmailMaterialButtonStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/padding_8"
                app:layout_constraintEnd_toStartOf="@id/end_16_line"
                app:layout_constraintStart_toEndOf="@id/start_16_line"
                app:layout_constraintTop_toBottomOf="@id/vacancy_contact_name"
                tools:text="abc@gmail.com"
                />
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/VacancyErrorFrameLayoutStyle"
        android:visibility="gone">
        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/img_job_unavailable"
            android:contentDescription="@string/vacancy_not_found"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/VacancyErrorTextViewStyle"
            android:text="@string/vacancy_not_found"
            />
    </FrameLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/VacancyErrorFrameLayoutStyle"
        android:visibility="gone">
        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/img_server_error_cat"
            android:contentDescription="@string/server_error"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/VacancyErrorTextViewStyle"
            android:text="@string/server_error"
            />
    </FrameLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        style="@style/VacancyErrorFrameLayoutStyle"
        android:visibility="gone">
        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/img_no_internet_connection"
            android:contentDescription="@string/no_internet"/>
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            style="@style/VacancyErrorTextViewStyle"
            android:text="@string/no_internet"
            />
    </FrameLayout>

    <ProgressBar
        android:layout_width="@dimen/progress_bar_size"
        android:layout_height="@dimen/progress_bar_size"
        android:indeterminateTint="?attr/colorPrimary"
        android:layout_gravity="center"
        android:visibility="gone"
        />

</FrameLayout>
