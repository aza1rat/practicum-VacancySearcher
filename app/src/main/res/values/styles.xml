<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Стиль для подписей в нижнем меню -->
    <style name="BottomNavTextStyle" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:fontFamily">@font/ys_display_regular</item>
        <item name="android:textSize">@dimen/text_size_12</item>
    </style>

    <!-- Стиль текст вью разработчиков проекта -->
    <style name="DevNameTextStyle">
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textSize">@dimen/text_size_16</item>
        <item name="android:layout_marginHorizontal">@dimen/padding_16</item>
        <item name="android:layout_marginBottom">@dimen/padding_16</item>
        <item name="android:textColor">?attr/colorOnBackgroundPrimary</item>
    </style>

    <!-- Стиль текст вью заголовка экрана -->
    <style name="ScreenTitleTextStyle">
        <item name="android:fontFamily">@font/ys_display_medium</item>
        <item name="android:textSize">@dimen/text_size_22</item>
        <item name="android:layout_marginStart">@dimen/padding_16</item>
        <item name="android:layout_marginEnd">@dimen/padding_8</item>
        <item name="android:paddingVertical">19dp</item>
        <item name="android:textColor">?attr/colorOnBackgroundPrimary</item>
    </style>

    <style name="roundedImageView">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">12dp</item>
    </style>

</resources>
